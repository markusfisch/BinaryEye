	<string name="format_description_aztec">Un code-barres matriciel 2D qui peut être lu sans zone blanche autour de lui. Souvent utilisé pour les billets de transport et les cartes d\'embarquement.</string>
	<string name="format_description_codabar">Un code-barres linéaire utilisé dans les bibliothèques, les banques de sang et les lettres de voiture FedEx depuis 1972. Encode des chiffres et quelques caractères spéciaux.</string>
	<string name="format_description_code39">Un code-barres linéaire à longueur variable encodant des lettres majuscules, des chiffres et quelques symboles. Très répandu dans l\'automobile et la défense.</string>
	<string name="format_description_code39ext">Code 39 étendu prenant en charge les 128 caractères ASCII complets. Utilise des paires de symboles Code 39 standard pour représenter les caractères supplémentaires.</string>
	<string name="format_description_code32">Une norme italienne de code-barres pharmaceutique également connue sous le nom IMH. Utilisée pour identifier les médicaments vendus en Italie.</string>
	<string name="format_description_pzn">La Pharmazentralnummer allemande, un code-barres utilisé pour identifier les produits pharmaceutiques vendus en Allemagne.</string>
	<string name="format_description_code93">Un code-barres linéaire alphanumérique compact encodant le jeu de caractères ASCII complet. Plus dense et plus sécurisé que le Code 39.</string>
	<string name="format_description_code128">Un code-barres linéaire haute densité encodant le jeu de caractères ASCII complet. Très répandu dans l\'expédition, l\'emballage et la gestion des stocks.</string>
	<string name="format_description_databar">Une famille de codes-barres GS1 compacts pour les articles trop petits pour les symboles EAN/UPC traditionnels. Encode les données GTIN avec des informations supplémentaires optionnelles.</string>
	<string name="format_description_databar_omni">DataBar Omnidirectionnel, lisable dans toutes les directions. Conçu pour les petits articles de vente au détail comme les produits frais.</string>
	<string name="format_description_databar_stk">DataBar Empilé, une version à deux rangées de DataBar pour les articles trop étroits pour un code-barres à une seule rangée.</string>
	<string name="format_description_databar_ltd">DataBar Limited, une variante compacte pour les articles dont le GTIN-14 commence par 0 ou 1.</string>
	<string name="format_description_databar_exp">DataBar Étendu, capable d\'encoder des données supplémentaires telles que le poids, le prix et la date d\'expiration en plus du GTIN.</string>
	<string name="format_description_databar_exp_stk">DataBar Étendu Empilé, une version à deux rangées de DataBar Étendu. Conçu pour les étiquettes étroites.</string>
	<string name="format_description_data_matrix">Un code-barres matriciel 2D encodant de grandes quantités de données dans un espace réduit. Très répandu dans l\'électronique, la santé et les services postaux.</string>
	<string name="format_description_dx_film_edge">Un code-barres imprimé sur le bord des films photographiques. Encode le type de film, la sensibilité (ISO) et le nombre de poses.</string>
	<string name="format_description_ean8">Un code-barres compact à 8 chiffres pour les petits articles de vente au détail où un EAN-13 complet ne tiendrait pas.</string>
	<string name="format_description_ean13">Le code-barres de vente au détail standard à 13 chiffres utilisé dans le monde entier. La plupart des produits vendus en magasin portent un EAN-13 sur leur emballage.</string>
	<string name="format_description_itf">Interleaved 2 of 5, un code-barres linéaire numérique uniquement encodant des paires de chiffres. Souvent utilisé sur les cartons extérieurs et dans la logistique d\'entrepôt.</string>
	<string name="format_description_maxicode">Un code-barres matriciel 2D de taille fixe développé par UPS. Utilisé pour le tri automatisé à haute vitesse et le suivi des colis.</string>
	<string name="format_description_pdf417">Un code-barres 2D empilé encodant de grandes quantités de données sur plusieurs rangées. Utilisé dans les documents d\'identité, les cartes d\'embarquement et les étiquettes d\'expédition.</string>
	<string name="format_description_qr_code">Un code-barres matriciel 2D largement utilisé, lisible par la plupart des appareils photo de smartphones. Peut encoder des URL, du texte, des informations de contact et plus encore.</string>
	<string name="format_description_micro_qr_code">Une variante plus petite du QR Code avec un seul motif de recherche. Conçu pour les applications où l\'espace est très limité.</string>
	<string name="format_description_rmqr_code">Rectangular Micro QR Code, une variante de code-barres 2D allongée. Conçu pour les étiquettes étroites et les bracelets.</string>
	<string name="format_description_upca">Le code-barres de vente au détail standard à 12 chiffres utilisé en Amérique du Nord. Un sous-ensemble d\'EAN-13, avec le zéro de tête implicite.</string>
	<string name="format_description_upce">Une version compressée à 6 chiffres de l\'UPC-A pour les petits emballages. Valide uniquement pour les produits dont l\'UPC-A peut être supprimé à zéro.</string>
