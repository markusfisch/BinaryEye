	<string name="format_description_aztec">En 2D-matrixstregkode, der kan læses uden en stille zone rundt om den. Bruges ofte til transportbilletter og boardingkort.</string>
	<string name="format_description_codabar">En lineær stregkode brugt i biblioteker, blodbanker og FedEx-fragtbreve siden 1972. Koder numeriske cifre og nogle specialtegn.</string>
	<string name="format_description_code39">En lineær stregkode med variabel længde, der koder store bogstaver, cifre og nogle symboler. Udbredt i bilindustrien og forsvaret.</string>
	<string name="format_description_code39ext">Udvidet Code 39 med understøttelse af alle 128 ASCII-tegn. Bruger par af standard Code 39-symboler til at repræsentere ekstra tegn.</string>
	<string name="format_description_code32">En italiensk farmaceutisk stregkodestandard også kendt som IMH. Bruges til at identificere lægemidler solgt i Italien.</string>
	<string name="format_description_pzn">Det tyske Pharmazentralnummer, en stregkode til at identificere farmaceutiske produkter solgt i Tyskland.</string>
	<string name="format_description_code93">En kompakt alfanumerisk lineær stregkode, der koder det fulde ASCII-tegnsæt. Tættere og mere sikker end Code 39.</string>
	<string name="format_description_code128">En lineær stregkode med høj tæthed, der koder det fulde ASCII-tegnsæt. Udbredt inden for forsendelse, emballage og lagerstyring.</string>
	<string name="format_description_databar">En familie af kompakte GS1-stregkoder til varer, der er for små til traditionelle EAN/UPC-symboler. Koder GTIN-data med valgfri supplerende oplysninger.</string>
	<string name="format_description_databar_omni">DataBar Omnidirektionel, der kan læses fra enhver retning. Designet til små detailhandelsvarer som friske produkter.</string>
	<string name="format_description_databar_stk">DataBar Stacked, en to-rækkers version af DataBar til varer, der er for smalle til en enkelt-rækkers stregkode.</string>
	<string name="format_description_databar_ltd">DataBar Limited, en kompakt variant til varer med et GTIN-14, der begynder med 0 eller 1.</string>
	<string name="format_description_databar_exp">DataBar Expanded, der kan kode supplerende data såsom vægt, pris og udløbsdato ved siden af GTIN.</string>
	<string name="format_description_databar_exp_stk">DataBar Expanded Stacked, en to-rækkers version af DataBar Expanded. Designet til smalle etiketter.</string>
	<string name="format_description_data_matrix">En 2D-matrixstregkode, der koder store mængder data på et lille område. Udbredt inden for elektronik, sundhedsvæsen og posttjenester.</string>
	<string name="format_description_dx_film_edge">En stregkode trykt langs kanten af fotografisk film. Koder filmtype, lysfølsomhed (ISO) og antal eksponeringer.</string>
	<string name="format_description_ean8">En kompakt 8-cifret stregkode til små detailhandelsvarer, hvor en fuld EAN-13 ikke passer.</string>
	<string name="format_description_ean13">Den standard 13-cifrede detailhandelsstregkode, der bruges verden over. De fleste produkter solgt i butikker har en EAN-13 på deres emballage.</string>
	<string name="format_description_itf">Interleaved 2 of 5, en kun-numerisk lineær stregkode, der koder par af cifre. Bruges ofte på ydre kartoner og i lagerlogistik.</string>
	<string name="format_description_maxicode">En 2D-matrixstregkode i fast størrelse udviklet af UPS. Bruges til automatiseret højhastighedssortering og sporing af pakker.</string>
	<string name="format_description_pdf417">En stablet 2D-stregkode, der koder store mængder data på tværs af flere rækker. Bruges i identitetsdokumenter, boardingkort og forsendelsesetiketter.</string>
	<string name="format_description_qr_code">En udbredt 2D-matrixstregkode, der kan læses af de fleste smartphone-kameraer. Kan kode URL\'er, tekst, kontaktoplysninger og mere.</string>
	<string name="format_description_micro_qr_code">En mindre variant af QR Code med et enkelt søgemønster. Designet til applikationer, hvor pladsen er meget begrænset.</string>
	<string name="format_description_rmqr_code">Rectangular Micro QR Code, en aflang 2D-stregkodevariant. Designet til smalle etiketter og armbånd.</string>
	<string name="format_description_upca">Den standard 12-cifrede detailhandelsstregkode brugt i Nordamerika. Et subset af EAN-13, med det indledende nul implicit.</string>
	<string name="format_description_upce">En komprimeret 6-cifret version af UPC-A til små pakker. Kun gyldig for produkter, hvis UPC-A kan nul-undertrykkes.</string>
