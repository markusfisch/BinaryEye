	<string name="format_description_codabar">Mã vạch tuyến tính được dùng trong thư viện, ngân hàng máu và vận đơn hàng không FedEx từ năm 1972. Mã hóa các chữ số và một số ký tự đặc biệt.</string>
	<string name="format_description_code39">Mã vạch tuyến tính có độ dài thay đổi, mã hóa các chữ cái in hoa, chữ số và một số ký hiệu. Được sử dụng rộng rãi trong ngành ô tô và quốc phòng.</string>
	<string name="format_description_code39ext">Code 39 mở rộng hỗ trợ toàn bộ 128 ký tự ASCII. Sử dụng các cặp ký hiệu Code 39 tiêu chuẩn để biểu thị các ký tự bổ sung.</string>
	<string name="format_description_code32">Tiêu chuẩn mã vạch dược phẩm của Ý, còn được gọi là IMH. Dùng để nhận dạng các loại thuốc bán tại Ý.</string>
	<string name="format_description_pzn">Pharmazentralnummer của Đức, mã vạch dùng để nhận dạng các sản phẩm dược phẩm bán tại Đức.</string>
	<string name="format_description_code93">Mã vạch tuyến tính chữ-số dạng gọn mã hóa toàn bộ bộ ký tự ASCII. Dày đặc và bảo mật hơn Code 39.</string>
	<string name="format_description_code128">Mã vạch tuyến tính mật độ cao mã hóa toàn bộ bộ ký tự ASCII. Được sử dụng rộng rãi trong vận chuyển, đóng gói và quản lý hàng tồn kho.</string>
	<string name="format_description_databar">Bộ mã vạch GS1 nhỏ gọn dành cho các mặt hàng quá nhỏ so với các ký hiệu EAN/UPC truyền thống. Mã hóa dữ liệu GTIN với thông tin bổ sung tùy chọn.</string>
	<string name="format_description_databar_omni">DataBar Omnidirectional, có thể đọc từ mọi hướng. Được thiết kế cho các mặt hàng bán lẻ nhỏ như rau củ quả tươi.</string>
	<string name="format_description_databar_stk">DataBar Stacked, phiên bản hai hàng của DataBar dành cho các mặt hàng quá hẹp cho mã vạch một hàng.</string>
	<string name="format_description_databar_ltd">DataBar Limited, biến thể nhỏ gọn dành cho các mặt hàng có GTIN-14 bắt đầu bằng 0 hoặc 1.</string>
	<string name="format_description_databar_exp">DataBar Expanded, có khả năng mã hóa dữ liệu bổ sung như trọng lượng, giá cả và ngày hết hạn cùng với GTIN.</string>
	<string name="format_description_databar_exp_stk">DataBar Expanded Stacked, phiên bản hai hàng của DataBar Expanded. Được thiết kế cho nhãn hẹp.</string>
	<string name="format_description_data_matrix">Mã vạch ma trận 2D mã hóa lượng lớn dữ liệu trong diện tích nhỏ. Được sử dụng rộng rãi trong điện tử, y tế và dịch vụ bưu chính.</string>
	<string name="format_description_dx_film_edge">Mã vạch in dọc theo cạnh phim ảnh. Mã hóa loại phim, tốc độ (ISO) và số lần phơi sáng.</string>
	<string name="format_description_ean8">Mã vạch 8 chữ số nhỏ gọn dành cho các mặt hàng bán lẻ nhỏ không đủ chỗ cho EAN-13 đầy đủ.</string>
	<string name="format_description_ean13">Mã vạch bán lẻ 13 chữ số tiêu chuẩn được sử dụng trên toàn thế giới. Hầu hết các sản phẩm bán trong cửa hàng đều có EAN-13 trên bao bì.</string>
	<string name="format_description_itf">Interleaved 2 of 5, mã vạch tuyến tính chỉ dùng số mã hóa các cặp chữ số. Thường được dùng trên thùng carton ngoài và trong logistics kho bãi.</string>
	<string name="format_description_maxicode">Mã vạch ma trận 2D kích thước cố định do UPS phát triển. Dùng để phân loại và theo dõi bưu kiện tự động tốc độ cao.</string>
	<string name="format_description_pdf417">Mã vạch 2D xếp chồng mã hóa lượng lớn dữ liệu qua nhiều hàng. Dùng trong giấy tờ tùy thân, thẻ lên máy bay và nhãn vận chuyển.</string>
	<string name="format_description_qr_code">Mã vạch ma trận 2D được sử dụng rộng rãi, hầu hết camera smartphone đều đọc được. Có thể mã hóa URL, văn bản, thông tin liên lạc và nhiều hơn nữa.</string>
	<string name="format_description_micro_qr_code">Biến thể nhỏ hơn của QR Code với một mẫu tìm kiếm duy nhất. Được thiết kế cho các ứng dụng có không gian rất hạn chế.</string>
	<string name="format_description_rmqr_code">Rectangular Micro QR Code, biến thể mã vạch 2D dạng dài hẹp. Được thiết kế cho nhãn hẹp và vòng đeo tay.</string>
	<string name="format_description_upca">Mã vạch bán lẻ 12 chữ số tiêu chuẩn được dùng ở Bắc Mỹ. Là tập con của EAN-13, với số 0 đứng đầu được hiểu ngầm.</string>
	<string name="format_description_upce">Phiên bản nén 6 chữ số của UPC-A dành cho gói nhỏ. Chỉ hợp lệ cho các sản phẩm mà UPC-A của chúng có thể được rút gọn bằng cách triệt tiêu số 0.</string>
